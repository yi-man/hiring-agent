{
  "name": "hiring-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Hiring Agent — recruitment assistant with chat, JD generation, workflow learning, and LLM observability",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx src/scripts/next-server.ts --dev",
    "build": "next build",
    "start": "NODE_ENV=production tsx src/scripts/next-server.ts",
    "postinstall": "prisma generate",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "seed:knowledge:xxwade": "bunx tsx src/scripts/seed-xxwade-knowledge.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "test": "jest --coverage --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:ci": "jest --ci --coverage --runInBand --coverageReporters=text-summary",
    "test:e2e": "playwright test",
    "test:e2e:playwright": "playwright test",
    "test:e2e:playwright:jd": "playwright test tests/e2e-playwright/jd-generator-real.spec.ts",
    "test:e2e:playwright:workflow": "playwright test tests/e2e-playwright/workflow-learning.spec.ts",
    "test:integration:chat": "bunx jest tests/integration/chat/real-deps.e2e.test.ts --runInBand --coverage=false",
    "test:integration:candidate-screening": "bunx jest tests/integration/candidate-screening/screening-flow.e2e.test.ts --runInBand --coverage=false",
    "test:integration:candidate-communication": "bunx jest tests/integration/candidate-communication/communication-flow.e2e.test.ts --runInBand --coverage=false",
    "test:integration:jd-publishing": "bunx jest tests/integration/jd-publishing/publish-flow.e2e.test.ts --runInBand --coverage=false",
    "browser:chrome-bridge": "tsx src/scripts/browser-chrome-bridge.ts",
    "jd:chrome-bridge": "bun run browser:chrome-bridge",
    "obs:run": "bunx tsx src/scripts/llm-observability-ops.ts",
    "obs:realtime": "bun run obs:run -- realtime",
    "obs:retention": "bun run obs:run -- retention",
    "candidate-screening:calibration": "bunx tsx src/scripts/candidate-screening-calibration.ts",
    "validation:resume-scoring": "bunx tsx src/scripts/validation-resume-scoring.ts",
    "validation:jd-evaluate": "bunx tsx src/scripts/validation-jd-evaluate.ts",
    "test:integration:auth": "bunx jest tests/integration/auth/real-deps-auth.e2e.test.ts --runInBand --coverage=false",
    "prepare": "husky",
    "clean": "rm -rf .next node_modules coverage",
    "reinstall": "bun run clean && bun install"
  },
  "dependencies": {
    "@heroui/button": "2.2.31",
    "@heroui/card": "2.2.27",
    "@heroui/checkbox": "2.3.31",
    "@heroui/chip": "2.2.24",
    "@heroui/divider": "2.2.23",
    "@heroui/input": "2.4.32",
    "@heroui/modal": "2.2.28",
    "@heroui/radio": "2.3.31",
    "@heroui/react": "2.8.9",
    "@heroui/switch": "2.2.26",
    "@heroui/system": "2.4.27",
    "@heroui/tabs": "2.2.28",
    "@heroui/theme": "2.4.26",
    "@hookform/resolvers": "3.10.0",
    "@langchain/core": "1.1.35",
    "@langchain/langgraph": "1.2.6",
    "@langchain/openai": "1.3.0",
    "@langchain/textsplitters": "1.0.1",
    "@prisma/client": "6.16.2",
    "ahooks": "3.9.6",
    "axios": "1.13.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "framer-motion": "12.34.3",
    "lucide-react": "0.575.0",
    "mermaid": "^11.16.0",
    "next": "16.1.6",
    "next-themes": "0.4.6",
    "pg": "8.22.0",
    "playwright": "1.58.2",
    "react": "18.3.1",
    "react-day-picker": "8.10.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.71.2",
    "react-markdown": "10.1.0",
    "recharts": "2.15.4",
    "redis": "5.11.0",
    "remark-gfm": "4.0.1",
    "sonner": "1.7.4",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7",
    "tsx": "4.21.0",
    "ws": "^8.21.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@eslint/eslintrc": "3.3.4",
    "@eslint/js": "9.39.3",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "29.5.14",
    "@types/node": "22.19.11",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "^8.18.1",
    "chalk": "5.6.2",
    "dotenv": "17.3.1",
    "eslint": "8.57.1",
    "eslint-config-next": "15.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "15.15.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "lint-staged": "15.5.2",
    "patch-package": "8.0.1",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.6.14",
    "prisma": "6.16.2",
    "semver": "7.7.4",
    "tailwindcss": "4.2.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11",
  "overrides": {
    "@langchain/langgraph-checkpoint": "1.0.1",
    "@langchain/langgraph-sdk": "1.8.2"
  },
  "patchedDependencies": {
    "@heroui/react-utils@2.1.14": "patches/@heroui__react-utils.patch",
    "@heroui/use-viewport-size@2.0.1": "patches/@heroui__use-viewport-size.patch"
  }
}
