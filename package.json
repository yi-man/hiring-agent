{
  "name": "hiring-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Hiring Agent — recruitment assistant with chat, JD generation, workflow learning, and LLM observability",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "test": "jest --coverage --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:ci": "jest --ci --coverage --runInBand --coverageReporters=text-summary",
    "test:e2e": "playwright test",
    "test:e2e:playwright": "playwright test",
    "test:e2e:playwright:jd": "playwright test tests/e2e-playwright/jd-generator-real.spec.ts",
    "test:e2e:playwright:workflow": "playwright test tests/e2e-playwright/workflow-learning.spec.ts",
    "test:integration:chat": "pnpm exec jest tests/integration/chat/real-deps.e2e.test.ts --runInBand --coverage=false",
    "obs:run": "pnpm exec tsx src/scripts/llm-observability-ops.ts",
    "obs:realtime": "pnpm obs:run -- realtime",
    "obs:retention": "pnpm obs:run -- retention",
    "test:integration:auth": "pnpm exec jest tests/integration/auth/real-deps-auth.e2e.test.ts --runInBand --coverage=false",
    "prepare": "husky",
    "clean": "rm -rf .next node_modules coverage",
    "reinstall": "pnpm clean && pnpm install"
  },
  "dependencies": {
    "@heroui/button": "^2.2.31",
    "@heroui/card": "^2.2.27",
    "@heroui/checkbox": "^2.3.31",
    "@heroui/chip": "^2.2.24",
    "@heroui/divider": "^2.2.23",
    "@heroui/input": "^2.4.32",
    "@heroui/modal": "^2.2.28",
    "@heroui/radio": "^2.3.31",
    "@heroui/react": "^2.8.9",
    "@heroui/switch": "^2.2.26",
    "@heroui/system": "^2.4.27",
    "@heroui/tabs": "^2.2.28",
    "@heroui/theme": "^2.4.26",
    "@hookform/resolvers": "^3.9.1",
    "@langchain/core": "^1.1.35",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/openai": "^1.3.0",
    "@langchain/textsplitters": "^1.0.1",
    "@prisma/client": "^6.16.2",
    "@qdrant/js-client-rest": "^1.17.0",
    "ahooks": "^3.8.4",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.4",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.0",
    "redis": "^5.11.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.20.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.4",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.4",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.2.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.4.3",
    "patch-package": "^8.0.1",
    "pg": "^8.22.0",
    "prettier": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.16.2",
    "semver": "^7.7.4",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.2"
}
