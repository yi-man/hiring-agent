# Environment Variables
# Baseline workflow: `.env` -> `.env.test`; then prepare `.env.development` / `.env.local` as needed.

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Hiring Agent"
NEXT_PUBLIC_APP_DESCRIPTION="AI-powered hiring assistant (chat, JD, workflow learning, observability)"

# Auth
# Local username/password auth is built in.
# Default local login: xxwade / hiring_2026

# Analytics
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Performance
NEXT_PUBLIC_ENABLE_MSW=false

# OpenAI-compatible LLM (LangChain / chat)
OPENAI_API_KEY=your_api_key
# 火山方舟（与豆包向量）：示例 https://ark.cn-beijing.volces.com/api/v3
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# RAG 向量：可使用独立 OpenAI-compatible embedding 服务；未设置 EMBEDDING_* 时回退到 OPENAI_*。
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
# 旧配置保留兼容：默认 doubao-embedding-vision-250615（走 /embeddings/multimodal）；OpenAI 可改为 text-embedding-3-small 等
OPENAI_EMBEDDING_MODEL=doubao-embedding-vision-250615
OPENAI_EMBEDDING_USE_MULTIMODAL=auto

# Chat persistence (PostgreSQL + Redis)
# Dedicated test resources are required for integration tests.
DATABASE_URL=postgresql://apple@127.0.0.1:5432/bia
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=apple
POSTGRES_PASSWORD=
POSTGRES_DATABASE=bia
POSTGRES_CI_SUFFIX=_ci
REDIS_URL=redis://127.0.0.1:6379
CHAT_REDIS_TTL_SECONDS=86400
CHAT_HISTORY_REHYDRATE_LIMIT=50
CHAT_TEST_REDIS_PREFIX=chat:test

# Conversation Markdown RAG (Qdrant)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=conversation_markdown_chunks
RAG_TOP_K=6
RAG_MIN_SCORE=0
RAG_CONTEXT_MAX_CHARS=6000
# Lease duration for stale running ingest job recovery.
RAG_INGEST_LEASE_MS=1800000
# User knowledge RAG stores vectors in PostgreSQL with the pgvector extension.
# Run `CREATE EXTENSION IF NOT EXISTS vector;` or apply Prisma migrations before indexing knowledge documents.

# JD Agent（运行时需要配置 OPENAI_API_KEY；测试环境会使用内置 mock）
# OPENAI_JSON_MODE=true 时若上游不支持 json_object，会自动重试不带该参数
OPENAI_JSON_MODE=true
# JD Agent 调用上游 LLM 超时（毫秒），默认 120000；慢网关请调大
# JD_LLM_TIMEOUT_MS=120000

# JD Publish Agent（本地 boss-like 招聘站）
BOSS_LIKE_BASE_URL=http://localhost:6183
BOSS_LIKE_EMPLOYER_USERNAME=admin
BOSS_LIKE_EMPLOYER_PASSWORD=boss123
# 非 development/test 环境必须显式配置上面三个变量；如需临时允许本地默认值可设为 true。
# BOSS_LIKE_ALLOW_LOCAL_DEFAULTS=true

# JD Publish Browser Executor Adapter
# playwright: 本进程 Playwright 执行器（默认）
# http-command: 通过 HTTP command/result transport 对接 Chrome extension、agent-browser server 等外部浏览器运行时
# 所有运行时 Playwright workflow 默认有头；只在 CI/服务器等无显示环境显式设为 true。
# PLAYWRIGHT_HEADLESS=false
# JD_PUBLISHING_BROWSER_EXECUTOR=playwright
# JD_PUBLISHING_BROWSER_COMMAND_ENDPOINT=http://127.0.0.1:4100/browser-command
# JD_PUBLISHING_BROWSER_COMMAND_TIMEOUT_MS=30000
