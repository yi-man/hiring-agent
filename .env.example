# Environment Variables
# Copy this file to .env.local to set your local environment variables

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Next.js 16 SSR Template"
NEXT_PUBLIC_APP_DESCRIPTION="A modern, production-ready Next.js 16 SSR template"

# Analytics
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Performance
NEXT_PUBLIC_ENABLE_MSW=false