# Environment Variables
# Baseline workflow: `.env` -> `.env.test`; then prepare `.env.development` / `.env.local` as needed.

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Next.js 16 SSR Template"
NEXT_PUBLIC_APP_DESCRIPTION="A modern, production-ready Next.js 16 SSR template"

# Auth (next-auth v4 / NEXTAUTH naming)
# Required for GitHub OAuth and auth integration tests.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_string
GITHUB_ID=replace_with_github_oauth_app_client_id
GITHUB_SECRET=replace_with_github_oauth_app_client_secret

# Analytics
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Performance
NEXT_PUBLIC_ENABLE_MSW=false

# OpenAI-compatible LLM (LangChain / chat)
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Chat persistence (MySQL + Redis)
# Dedicated test resources are required for integration tests.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=mysql1234
MYSQL_DATABASE=bia
MYSQL_CI_SUFFIX=_ci
REDIS_URL=redis://127.0.0.1:6379
CHAT_REDIS_TTL_SECONDS=86400
CHAT_HISTORY_REHYDRATE_LIMIT=50
CHAT_TEST_REDIS_PREFIX=chat:test

# JD Agent（不设 OPENAI_API_KEY 或 JD_LLM_MOCK=true 时使用内置 mock）
# OPENAI_JSON_MODE=true 时若上游不支持 json_object，会自动重试不带该参数
OPENAI_JSON_MODE=true
JD_LLM_MOCK=false
# JD Agent 调用上游 LLM 超时（毫秒），默认 120000；慢网关请调大
# JD_LLM_TIMEOUT_MS=120000
