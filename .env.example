# Environment Variables
# Copy this file to .env.local to set your local environment variables

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Next.js 16 SSR Template"
NEXT_PUBLIC_APP_DESCRIPTION="A modern, production-ready Next.js 16 SSR template"

# Analytics
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Performance
NEXT_PUBLIC_ENABLE_MSW=false

# OpenAI-compatible LLM (LangChain / chat)
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# JD Agent（不设 OPENAI_API_KEY 或 JD_LLM_MOCK=true 时使用内置 mock）
OPENAI_JSON_MODE=true
JD_LLM_MOCK=false
