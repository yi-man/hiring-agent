generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id             String                      @id @default(uuid())
  userId         String?                     @map("user_id")
  title          String?
  status         String                      @default("active")
  lastActiveAt   DateTime                    @map("last_active_at")
  createdAt      DateTime                    @default(now()) @map("created_at")
  updatedAt      DateTime                    @updatedAt @map("updated_at")
  messages       Message[]
  documents      ConversationDocument[]
  documentChunks ConversationDocumentChunk[]
  user           User?                       @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Restrict)

  @@index([lastActiveAt(sort: Desc)])
  @@index([userId], map: "idx_conversations_user_id")
  @@map("conversations")
}

model User {
  id                      String                   @id @default(cuid())
  username                String                   @unique
  passwordHash            String                   @map("password_hash")
  name                    String?
  email                   String?                  @unique
  emailVerified           DateTime?                @map("email_verified")
  image                   String?
  sessions                Session[]
  conversations           Conversation[]
  jobDescriptions         JobDescription[]
  jobPublishTasks         JobPublishTask[]
  knowledgeDocuments      KnowledgeDocument[]
  knowledgeDocumentChunks KnowledgeDocumentChunk[]
  candidates              Candidate[]
  candidateResumes        CandidateResume[]
  candidateResumeChunks   CandidateResumeChunk[]
  candidateScreeningRuns  CandidateScreeningRun[]
  candidateScreeningResults CandidateScreeningResult[]
  candidateActionLogs       CandidateActionLog[]
  candidateTagStats       CandidateTagStat[]
  candidateInterviewFeedbacks CandidateInterviewFeedback[]
  candidateConversations         CandidateConversation[]
  candidateConversationMessages  CandidateConversationMessage[]
  candidateConversationDecisions CandidateConversationDecision[]
  candidateConversationMemories  CandidateConversationMemory[]
  candidateCommunicationRuns     CandidateCommunicationRun[]
  companyProfile                 CompanyProfile?

  @@map("users")
}

model CompanyProfile {
  id        String                @id @default(uuid())
  userId    String                @unique @map("user_id")
  name      String
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  locations CompanyWorkLocation[]

  @@index([userId], map: "idx_company_profiles_user_id")
  @@map("company_profiles")
}

model CompanyWorkLocation {
  id               String         @id @default(uuid())
  companyProfileId String         @map("company_profile_id")
  kind             String
  label            String
  city             String?
  address          String?
  sortOrder        Int            @default(0) @map("sort_order")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([companyProfileId, sortOrder], map: "idx_company_work_locations_profile_sort")
  @@map("company_work_locations")
}

model JobDescription {
  id                  String           @id @default(uuid())
  userId              String           @map("user_id")
  department          String
  position            String
  positionDescription String           @map("position_description")
  tone                String           @default("tech")
  status              String           @default("created")
  salaryRange         String?          @map("salary_range")
  workLocations       Json?            @map("work_locations")
  content             Json
  evaluation          Json?
  generationMeta      Json?            @map("generation_meta")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  publishTasks        JobPublishTask[]
  candidateScreeningRuns    CandidateScreeningRun[]
  candidateScreeningResults CandidateScreeningResult[]
  candidateActionLogs       CandidateActionLog[]
  candidateInterviewFeedbacks CandidateInterviewFeedback[]
  candidateConversations         CandidateConversation[]
  candidateConversationMessages  CandidateConversationMessage[]
  candidateConversationDecisions CandidateConversationDecision[]
  candidateConversationMemories  CandidateConversationMemory[]
  candidateCommunicationRuns     CandidateCommunicationRun[]

  @@index([userId], map: "idx_job_descriptions_user_id")
  @@index([status], map: "idx_job_descriptions_status")
  @@index([updatedAt(sort: Desc)], map: "idx_job_descriptions_updated_at")
  @@index([userId, status], map: "idx_job_descriptions_user_status")
  @@unique([id, userId], map: "job_descriptions_id_user_id_key")
  @@map("job_descriptions")
}

model PublishSkill {
  id          String            @id @default(uuid())
  name        String
  platform    String
  description String
  version     Int
  isActive    Boolean           @default(true) @map("is_active")
  inputSchema Json              @map("input_schema")
  variables   Json
  steps       Json
  meta        Json?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  tasks       JobPublishTask[]
  traces      JobPublishTrace[]

  @@unique([name, platform, version], map: "publish_skills_name_platform_version_key")
  @@index([name, platform, isActive, version], map: "idx_publish_skills_lookup")
  @@index([platform, isActive], map: "idx_publish_skills_platform_active")
  @@map("publish_skills")
}

model JobPublishTask {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  jobDescriptionId String           @map("job_description_id")
  skillId          String           @map("skill_id")
  platform         String
  input            Json
  currentStep      String?          @map("current_step")
  status           String           @default("running")
  errorMessage     String?          @map("error_message")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  jobDescription   JobDescription   @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  skill            PublishSkill     @relation(fields: [skillId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  trace            JobPublishTrace?

  @@index([userId, jobDescriptionId, createdAt(sort: Desc)], map: "idx_job_publish_tasks_user_jd_created")
  @@index([status], map: "idx_job_publish_tasks_status")
  @@index([skillId], map: "idx_job_publish_tasks_skill_id")
  @@map("job_publish_tasks")
}

model JobPublishTrace {
  id        String         @id @default(uuid())
  taskId    String         @unique @map("task_id")
  skillId   String         @map("skill_id")
  status    String
  steps     Json
  createdAt DateTime       @default(now()) @map("created_at")
  task      JobPublishTask @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  skill     PublishSkill   @relation(fields: [skillId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([skillId], map: "idx_job_publish_traces_skill_id")
  @@index([status], map: "idx_job_publish_traces_status")
  @@map("job_publish_traces")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([userId], map: "idx_sessions_user_id")
  @@map("sessions")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  role           String
  content        String
  documentId     String?      @map("document_id")
  seq            Int
  tokenCount     Int?         @map("token_count")
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([conversationId, seq])
  @@index([conversationId, seq], map: "idx_messages_conversation_seq")
  @@map("messages")
}

model ConversationDocument {
  id              String                         @id @default(uuid())
  conversationId  String                         @map("conversation_id")
  filename        String
  contentMarkdown String                         @map("content_markdown")
  status          String                         @default("processing")
  errorMessage    String?                        @map("error_message")
  version         Int                            @default(1)
  createdAt       DateTime                       @default(now()) @map("created_at")
  updatedAt       DateTime                       @updatedAt @map("updated_at")
  chunks          ConversationDocumentChunk[]
  jobs            ConversationDocumentIndexJob[]
  conversation    Conversation                   @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([id, conversationId], map: "conversation_documents_id_conversation_id_key")
  @@index([conversationId], map: "idx_conversation_documents_conversation_id")
  @@index([status], map: "idx_conversation_documents_status")
  @@map("conversation_documents")
}

model ConversationDocumentChunk {
  id             String               @id @default(uuid())
  documentId     String               @map("document_id")
  conversationId String               @map("conversation_id")
  chunkIndex     Int                  @map("chunk_index")
  content        String
  tokenEstimate  Int?                 @map("token_estimate")
  qdrantPointId  String?              @unique @map("qdrant_point_id")
  createdAt      DateTime             @default(now()) @map("created_at")
  document       ConversationDocument @relation(fields: [documentId, conversationId], references: [id, conversationId], onDelete: Cascade, onUpdate: Restrict)
  conversation   Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([documentId, chunkIndex], map: "conversation_document_chunks_document_id_chunk_index_key")
  @@index([documentId], map: "idx_conversation_document_chunks_document_id")
  @@index([conversationId], map: "idx_conversation_document_chunks_conversation_id")
  @@index([conversationId, chunkIndex], map: "idx_conversation_document_chunks_conversation_chunk_index")
  @@map("conversation_document_chunks")
}

model ConversationDocumentIndexJob {
  id         String               @id @default(uuid())
  documentId String               @map("document_id")
  status     String               @default("pending")
  attempts   Int                  @default(0)
  lastError  String?              @map("last_error")
  startedAt  DateTime?            @map("started_at")
  finishedAt DateTime?            @map("finished_at")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")
  document   ConversationDocument @relation(fields: [documentId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([documentId], map: "idx_conversation_document_index_jobs_document_id")
  @@index([status], map: "idx_conversation_document_index_jobs_status")
  @@map("conversation_document_index_jobs")
}

model KnowledgeDocument {
  id              String                      @id @default(uuid())
  userId          String                      @map("user_id")
  filename        String
  title           String?
  sourceLabel     String?                     @map("source_label")
  contentMarkdown String                      @map("content_markdown")
  status          String                      @default("processing")
  errorMessage    String?                     @map("error_message")
  version         Int                         @default(1)
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")
  user            User                        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  chunks          KnowledgeDocumentChunk[]
  jobs            KnowledgeDocumentIndexJob[]

  @@unique([id, userId], map: "knowledge_documents_id_user_id_key")
  @@index([userId], map: "idx_knowledge_documents_user_id")
  @@index([status], map: "idx_knowledge_documents_status")
  @@index([userId, sourceLabel], map: "idx_knowledge_documents_user_source_label")
  @@map("knowledge_documents")
}

model KnowledgeDocumentChunk {
  id                 String                 @id @default(uuid())
  documentId         String                 @map("document_id")
  userId             String                 @map("user_id")
  chunkIndex         Int                    @map("chunk_index")
  content            String
  tokenEstimate      Int?                   @map("token_estimate")
  embeddingModel     String                 @map("embedding_model")
  embeddingDimension Int                    @map("embedding_dimension")
  embedding          Unsupported("vector")?
  createdAt          DateTime               @default(now()) @map("created_at")
  document           KnowledgeDocument      @relation(fields: [documentId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([documentId, chunkIndex], map: "knowledge_document_chunks_document_id_chunk_index_key")
  @@index([documentId], map: "idx_knowledge_document_chunks_document_id")
  @@index([userId], map: "idx_knowledge_document_chunks_user_id")
  @@index([userId, embeddingModel, embeddingDimension], map: "idx_knowledge_document_chunks_user_embedding")
  @@map("knowledge_document_chunks")
}

model KnowledgeDocumentIndexJob {
  id         String            @id @default(uuid())
  documentId String            @map("document_id")
  status     String            @default("pending")
  attempts   Int               @default(0)
  lastError  String?           @map("last_error")
  startedAt  DateTime?         @map("started_at")
  finishedAt DateTime?         @map("finished_at")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([documentId], map: "idx_knowledge_document_index_jobs_document_id")
  @@index([status], map: "idx_knowledge_document_index_jobs_status")
  @@map("knowledge_document_index_jobs")
}

model Candidate {
  id                        String                     @id @default(uuid())
  userId                    String                     @map("user_id")
  displayName               String                     @map("display_name")
  currentTitle              String?                    @map("current_title")
  currentCompany            String?                    @map("current_company")
  location                  String?
  experienceYears           Float?                     @map("experience_years")
  sourcePlatform            String                     @map("source_platform")
  platformCandidateId       String?                    @map("platform_candidate_id")
  profileUrl                String?                    @map("profile_url")
  identityKey               String                     @map("identity_key")
  identityHash              String                     @map("identity_hash")
  lastActiveAt              DateTime?                  @map("last_active_at")
  contacted                 Boolean                    @default(false)
  replied                   Boolean                    @default(false)
  lastContactAt             DateTime?                  @map("last_contact_at")
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  user                      User                       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  resumes                   CandidateResume[]
  chunks                    CandidateResumeChunk[]
  screeningResults          CandidateScreeningResult[]
  actionLogs                CandidateActionLog[]
  interviewFeedbacks        CandidateInterviewFeedback[]
  conversations         CandidateConversation[]
  conversationMessages  CandidateConversationMessage[]
  conversationDecisions CandidateConversationDecision[]
  conversationMemories  CandidateConversationMemory[]
  communicationRuns     CandidateCommunicationRun[]

  @@unique([id, userId], map: "candidates_id_user_id_key")
  @@unique([userId, sourcePlatform, identityHash], map: "candidates_user_source_identity_hash_key")
  @@index([userId, updatedAt(sort: Desc)], map: "idx_candidates_user_updated_at")
  @@index([userId, contacted, replied], map: "idx_candidates_user_contacted_replied")
  @@map("candidates")
}

model CandidateResume {
  id                String                     @id @default(uuid())
  userId            String                     @map("user_id")
  candidateId       String                     @map("candidate_id")
  sourcePlatform    String                     @map("source_platform")
  profileUrl        String?                    @map("profile_url")
  rawText           String                     @map("raw_text")
  structuredSummary Json?                      @map("structured_summary")
  resumeHash        String                     @map("resume_hash")
  fetchedAt         DateTime                   @map("fetched_at")
  createdAt         DateTime                   @default(now()) @map("created_at")
  user              User                       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  candidate         Candidate                  @relation(fields: [candidateId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  chunks            CandidateResumeChunk[]
  screeningResults  CandidateScreeningResult[]

  @@unique([id, userId], map: "candidate_resumes_id_user_id_key")
  @@unique([id, candidateId, userId], map: "candidate_resumes_id_candidate_user_key")
  @@unique([candidateId, resumeHash], map: "candidate_resumes_candidate_hash_key")
  @@index([candidateId], map: "idx_candidate_resumes_candidate_id")
  @@index([userId, candidateId, fetchedAt(sort: Desc)], map: "idx_candidate_resumes_user_candidate_fetched")
  @@map("candidate_resumes")
}

model CandidateResumeChunk {
  id                 String          @id @default(uuid())
  userId             String          @map("user_id")
  candidateId        String          @map("candidate_id")
  resumeId           String          @map("resume_id")
  chunkIndex         Int             @map("chunk_index")
  content            String
  tokenEstimate      Int?            @map("token_estimate")
  embeddingModel     String          @map("embedding_model")
  embeddingDimension Int             @map("embedding_dimension")
  embedding          Unsupported("vector")?
  createdAt          DateTime        @default(now()) @map("created_at")
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  candidate          Candidate       @relation(fields: [candidateId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  resume             CandidateResume @relation(fields: [resumeId, candidateId, userId], references: [id, candidateId, userId], onDelete: Cascade, onUpdate: Restrict)

  @@unique([resumeId, chunkIndex], map: "candidate_resume_chunks_resume_chunk_key")
  @@index([candidateId], map: "idx_candidate_resume_chunks_candidate_id")
  @@index([userId, embeddingModel, embeddingDimension], map: "idx_candidate_resume_chunks_user_embedding")
  @@map("candidate_resume_chunks")
}

model CandidateScreeningRun {
  id               String                     @id @default(uuid())
  userId           String                     @map("user_id")
  jobDescriptionId String                     @map("job_description_id")
  platform         String
  mode             String                     @default("dry_run")
  status           String                     @default("pending")
  currentStage     String?                    @map("current_stage")
  searchPlan       Json?                      @map("search_plan")
  evaluationSchema Json?                      @map("evaluation_schema")
  stats            Json?
  errorMessage     String?                    @map("error_message")
  startedAt        DateTime?                  @map("started_at")
  finishedAt       DateTime?                  @map("finished_at")
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @updatedAt @map("updated_at")
  user             User                       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  jobDescription   JobDescription             @relation(fields: [jobDescriptionId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  results          CandidateScreeningResult[]
  actionLogs       CandidateActionLog[]

  @@unique([id, userId], map: "candidate_screening_runs_id_user_id_key")
  @@unique([id, userId, jobDescriptionId], map: "candidate_screening_runs_id_user_jd_key")
  @@index([userId, jobDescriptionId, createdAt(sort: Desc)], map: "idx_candidate_screening_runs_user_jd_created")
  @@index([status, updatedAt(sort: Desc)], map: "idx_candidate_screening_runs_status_updated")
  @@map("candidate_screening_runs")
}

model CandidateScreeningResult {
  id               String                 @id @default(uuid())
  userId           String                 @map("user_id")
  runId            String                 @map("run_id")
  jobDescriptionId String                 @map("job_description_id")
  candidateId      String                 @map("candidate_id")
  resumeId         String?                @map("resume_id")
  source           String
  tags             Json
  scoreDetail      Json                   @map("score_detail")
  finalScore       Float                  @map("final_score")
  rank             Int
  decisionAction   String                 @map("decision_action")
  decisionPriority String                 @map("decision_priority")
  decisionReason   String                 @map("decision_reason")
  actionPlan       Json?                  @map("action_plan")
  actionStatus     String                 @default("planned") @map("action_status")
  interviewStage   String                 @default("screened") @map("interview_stage")
  notes            String?
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  run              CandidateScreeningRun  @relation(fields: [runId, userId, jobDescriptionId], references: [id, userId, jobDescriptionId], onDelete: Cascade, onUpdate: Restrict)
  jobDescription   JobDescription         @relation(fields: [jobDescriptionId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  candidate        Candidate              @relation(fields: [candidateId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  resume           CandidateResume?       @relation(fields: [resumeId, candidateId, userId], references: [id, candidateId, userId], onDelete: Restrict, onUpdate: Restrict)
  actionLogs       CandidateActionLog[]

  @@unique([id, userId], map: "candidate_screening_results_id_user_id_key")
  @@unique([id, userId, runId, jobDescriptionId, candidateId], map: "candidate_screening_results_id_user_run_jd_candidate_key")
  @@unique([id, userId, jobDescriptionId, candidateId], map: "candidate_screening_results_id_user_jd_candidate_key")
  @@unique([jobDescriptionId, candidateId], map: "candidate_screening_results_jd_candidate_key")
  @@index([runId], map: "idx_candidate_screening_results_run_id")
  @@index([candidateId], map: "idx_candidate_screening_results_candidate_id")
  @@index([userId, jobDescriptionId, finalScore(sort: Desc)], map: "idx_candidate_screening_results_user_jd_score")
  @@index([userId, jobDescriptionId, interviewStage], map: "idx_candidate_screening_results_user_jd_stage")
  @@map("candidate_screening_results")
}

model CandidateActionLog {
  id                String                   @id @default(uuid())
  userId            String                   @map("user_id")
  runId             String                   @map("run_id")
  screeningResultId String                   @map("screening_result_id")
  candidateId       String                   @map("candidate_id")
  jobDescriptionId  String                   @map("job_description_id")
  platform          String
  mode              String
  action            String
  message           String?
  status            String
  idempotencyKey    String                   @map("idempotency_key")
  browserTrace      Json?                    @map("browser_trace")
  errorMessage      String?                  @map("error_message")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  run               CandidateScreeningRun    @relation(fields: [runId, userId, jobDescriptionId], references: [id, userId, jobDescriptionId], onDelete: Cascade, onUpdate: Restrict)
  screeningResult   CandidateScreeningResult @relation(fields: [screeningResultId, userId, jobDescriptionId, candidateId], references: [id, userId, jobDescriptionId, candidateId], onDelete: Cascade, onUpdate: Restrict)
  candidate         Candidate                @relation(fields: [candidateId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  jobDescription    JobDescription           @relation(fields: [jobDescriptionId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)

  @@unique([userId, idempotencyKey], map: "candidate_action_logs_user_idempotency_key")
  @@index([runId], map: "idx_candidate_action_logs_run_id")
  @@index([screeningResultId], map: "idx_candidate_action_logs_screening_result_id")
  @@index([candidateId], map: "idx_candidate_action_logs_candidate_id")
  @@index([userId, jobDescriptionId, candidateId, createdAt(sort: Desc)], map: "idx_candidate_action_logs_user_jd_candidate_created")
  @@map("candidate_action_logs")
}

model CandidateInterviewFeedback {
  id               String         @id @default(uuid())
  userId           String         @map("user_id")
  jobDescriptionId String         @map("job_description_id")
  candidateId      String         @map("candidate_id")
  stage            String
  interviewer      String
  rating           Float
  pros             Json
  cons             Json
  decision         String
  notes            String?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  jobDescription   JobDescription @relation(fields: [jobDescriptionId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  candidate        Candidate      @relation(fields: [candidateId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)

  @@unique([userId, jobDescriptionId, candidateId, stage], map: "candidate_interview_feedbacks_user_jd_candidate_stage_key")
