model CandidateConversation {
  id                     String                          @id @default(uuid())
  userId                 String                          @map("user_id")
  jobDescriptionId       String                          @map("job_description_id")
  candidateId            String                          @map("candidate_id")
  platform               String
  stage                  String                          @default("new")
  status                 String                          @default("active")
  intentLevel            String?                         @map("intent_level")
  messageCount           Int                             @default(0) @map("message_count")
  lastActiveAt           DateTime                        @map("last_active_at")
  lastCandidateMessageAt DateTime?                       @map("last_candidate_message_at")
  lastAgentMessageAt     DateTime?                       @map("last_agent_message_at")
  nextFollowUpAt         DateTime?                       @map("next_follow_up_at")
  outcomeResult          String?                         @map("outcome_result")
  outcomeReason          String?                         @map("outcome_reason")
  createdAt              DateTime                        @default(now()) @map("created_at")
  updatedAt              DateTime                        @updatedAt @map("updated_at")
  user                   User                            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  jobDescription         JobDescription                  @relation(fields: [jobDescriptionId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  candidate              Candidate                       @relation(fields: [candidateId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  messages               CandidateConversationMessage[]
  decisions              CandidateConversationDecision[]
  memories               CandidateConversationMemory[]

  @@unique([id, userId, jobDescriptionId, candidateId], map: "candidate_conversations_id_user_jd_candidate_key")
  @@unique([userId, jobDescriptionId, candidateId], map: "candidate_conversations_user_jd_candidate_key")
  @@index([userId, stage, updatedAt(sort: Desc)], map: "idx_candidate_conversations_user_stage_updated")
  @@index([candidateId], map: "idx_candidate_conversations_candidate_id")
  @@map("candidate_conversations")
}

