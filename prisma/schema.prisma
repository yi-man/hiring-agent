generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id           String    @id @default(uuid()) @db.VarChar(36)
  userId       String?   @map("user_id") @db.VarChar(128)
  title        String?   @db.VarChar(255)
  status       String    @default("active") @db.VarChar(32)
  lastActiveAt DateTime  @map("last_active_at") @db.DateTime(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  messages     Message[]
  documents    ConversationDocument[]
  documentChunks ConversationDocumentChunk[]
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Restrict)

  @@index([lastActiveAt(sort: Desc)])
  @@index([userId], map: "idx_conversations_user_id")
  @@map("conversations")
}

model User {
  id            String         @id @default(cuid()) @db.VarChar(128)
  name          String?        @db.VarChar(191)
  email         String?        @unique @db.VarChar(191)
  emailVerified DateTime?      @db.DateTime(3)
  image         String?        @db.VarChar(191)
  accounts      Account[]
  sessions      Session[]
  conversations Conversation[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid()) @db.VarChar(128)
  userId            String  @db.VarChar(128)
  type              String  @db.VarChar(191)
  provider          String  @db.VarChar(191)
  providerAccountId String  @db.VarChar(191)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(191)
  scope             String? @db.VarChar(191)
  id_token          String? @db.Text
  session_state     String? @db.VarChar(191)
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "idx_accounts_user_id")
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid()) @db.VarChar(128)
  sessionToken String   @unique @db.VarChar(191)
  userId       String   @db.VarChar(128)
  expires      DateTime @db.DateTime(3)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([userId], map: "idx_sessions_user_id")
  @@map("sessions")
}

model VerificationToken {
  identifier String @db.VarChar(191)
  token      String @unique @db.VarChar(191)
  expires    DateTime @db.DateTime(3)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Message {
  id             String       @id @default(uuid()) @db.VarChar(36)
  conversationId String       @map("conversation_id") @db.VarChar(36)
  role           String       @db.VarChar(16)
  content        String       @db.LongText
  seq            Int
  tokenCount     Int?         @map("token_count")
  createdAt      DateTime     @default(now()) @map("created_at") @db.DateTime(3)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([conversationId, seq], map: "idx_messages_conversation_seq")
  @@unique([conversationId, seq])
  @@map("messages")
}

model ConversationDocument {
  id              String                         @id @default(uuid()) @db.VarChar(36)
  conversationId  String                         @map("conversation_id") @db.VarChar(36)
  filename        String                         @db.VarChar(255)
  contentMarkdown String                         @map("content_markdown") @db.LongText
  status          String                         @default("processing") @db.VarChar(32)
  errorMessage    String?                        @map("error_message") @db.Text
  version         Int                            @default(1)
  createdAt       DateTime                       @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt       DateTime                       @updatedAt @map("updated_at") @db.DateTime(3)
  chunks          ConversationDocumentChunk[]
  jobs            ConversationDocumentIndexJob[]
  conversation    Conversation                   @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([conversationId], map: "idx_conversation_documents_conversation_id")
  @@index([status], map: "idx_conversation_documents_status")
  @@map("conversation_documents")
}

model ConversationDocumentChunk {
  id            String               @id @default(uuid()) @db.VarChar(36)
  documentId    String               @map("document_id") @db.VarChar(36)
  conversationId String              @map("conversation_id") @db.VarChar(36)
  chunkIndex    Int                  @map("chunk_index")
  content       String               @db.LongText
  tokenEstimate Int?                 @map("token_estimate")
  qdrantPointId String?              @unique @map("qdrant_point_id") @db.VarChar(128)
  createdAt     DateTime             @default(now()) @map("created_at") @db.DateTime(3)
  document      ConversationDocument @relation(fields: [documentId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  conversation  Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([documentId, chunkIndex], map: "conversation_document_chunks_document_id_chunk_index_key")
  @@index([documentId], map: "idx_conversation_document_chunks_document_id")
  @@index([conversationId], map: "idx_conversation_document_chunks_conversation_id")
  @@index([conversationId, chunkIndex], map: "idx_conversation_document_chunks_conversation_chunk_index")
  @@map("conversation_document_chunks")
}

model ConversationDocumentIndexJob {
  id         String               @id @default(uuid()) @db.VarChar(36)
  documentId String               @map("document_id") @db.VarChar(36)
  status     String               @default("pending") @db.VarChar(32)
  attempts   Int                  @default(0)
  lastError  String?              @map("last_error") @db.Text
  startedAt  DateTime?            @map("started_at") @db.DateTime(3)
  finishedAt DateTime?            @map("finished_at") @db.DateTime(3)
  createdAt  DateTime             @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt  DateTime             @updatedAt @map("updated_at") @db.DateTime(3)
  document   ConversationDocument @relation(fields: [documentId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([documentId], map: "idx_conversation_document_index_jobs_document_id")
  @@index([status], map: "idx_conversation_document_index_jobs_status")
  @@map("conversation_document_index_jobs")
}

model LlmCallLog {
  id             String   @id @default(uuid()) @db.VarChar(36)
  callId         String?  @map("call_id") @db.VarChar(128)
  traceId        String?  @map("trace_id") @db.VarChar(128)
  requestId      String?  @map("request_id") @db.VarChar(128)
  endpoint       String   @db.VarChar(128)
  provider       String   @db.VarChar(64)
  model          String   @db.VarChar(128)
  requestHeaders Json     @map("request_headers")
  requestPayload Json     @map("request_payload")
  responsePayload Json?   @map("response_payload")
  inputTokens    Int      @map("input_tokens")
  outputTokens   Int      @map("output_tokens")
  totalTokens    Int      @map("total_tokens")
  latencyMs      Int      @map("latency_ms")
  httpStatus     Int?     @map("http_status")
  isError        Boolean  @default(false) @map("is_error")
  errorDomain    String?  @map("error_domain") @db.VarChar(64)
  errorCode      String?  @map("error_code") @db.VarChar(128)
  providerStatus String?  @map("provider_status") @db.VarChar(128)
  retryCount     Int      @default(0) @map("retry_count")
  finalOutcome   String   @map("final_outcome") @db.VarChar(32)
  timestamp      DateTime @db.DateTime(3)
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(3)

  @@unique([callId], map: "llm_call_logs_call_id_key")
  @@unique([provider, requestId], map: "llm_call_logs_provider_request_id_key")
  @@index([timestamp], map: "idx_llm_call_logs_timestamp")
  @@index([isError, timestamp], map: "idx_llm_call_logs_is_error_timestamp")
  @@index([provider, model, timestamp], map: "idx_llm_call_logs_provider_model_timestamp")
  @@index([endpoint, timestamp], map: "idx_llm_call_logs_endpoint_timestamp")
  @@map("llm_call_logs")
}

model LlmUsageStatsDaily {
  id          String   @id @default(uuid()) @db.VarChar(36)
  bucketDate  DateTime @map("bucket_date") @db.Date
  provider    String   @db.VarChar(64)
  model       String   @db.VarChar(128)
  endpoint    String   @db.VarChar(128)
  totalCalls  Int      @default(0) @map("total_calls")
  successCalls Int     @default(0) @map("success_calls")
  errorCalls  Int      @default(0) @map("error_calls")
  inputTokens Int      @default(0) @map("input_tokens")
  outputTokens Int     @default(0) @map("output_tokens")
  totalTokens Int      @default(0) @map("total_tokens")
  avgLatencyMs Float   @default(0) @map("avg_latency_ms")
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@unique([bucketDate, provider, model, endpoint], map: "llm_usage_stats_daily_bucket_provider_model_endpoint_key")
  @@index([bucketDate], map: "idx_llm_usage_stats_daily_bucket_date")
  @@map("llm_usage_stats_daily")
}

model LlmUsageStatsWeekly {
  id           String   @id @default(uuid()) @db.VarChar(36)
  bucketWeek   DateTime @map("bucket_week") @db.Date
  provider     String   @db.VarChar(64)
  model        String   @db.VarChar(128)
  endpoint     String   @db.VarChar(128)
  totalCalls   Int      @default(0) @map("total_calls")
  successCalls Int      @default(0) @map("success_calls")
  errorCalls   Int      @default(0) @map("error_calls")
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  totalTokens  Int      @default(0) @map("total_tokens")
  avgLatencyMs Float    @default(0) @map("avg_latency_ms")
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@unique([bucketWeek, provider, model, endpoint], map: "llm_usage_stats_weekly_bucket_provider_model_endpoint_key")
  @@index([bucketWeek], map: "idx_llm_usage_stats_weekly_bucket_week")
  @@map("llm_usage_stats_weekly")
}

model LlmUsageStatsTotal {
  id           String   @id @default(uuid()) @db.VarChar(36)
  provider     String   @db.VarChar(64)
  model        String   @db.VarChar(128)
  endpoint     String   @db.VarChar(128)
  totalCalls   Int      @default(0) @map("total_calls")
  successCalls Int      @default(0) @map("success_calls")
  errorCalls   Int      @default(0) @map("error_calls")
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  totalTokens  Int      @default(0) @map("total_tokens")
  avgLatencyMs Float    @default(0) @map("avg_latency_ms")
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@unique([provider, model, endpoint], map: "llm_usage_stats_total_provider_model_endpoint_key")
  @@map("llm_usage_stats_total")
}
