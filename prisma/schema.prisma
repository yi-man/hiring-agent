generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id             String                      @id @default(uuid())
  userId         String?                     @map("user_id")
  title          String?
  status         String                      @default("active")
  lastActiveAt   DateTime                    @map("last_active_at")
  createdAt      DateTime                    @default(now()) @map("created_at")
  updatedAt      DateTime                    @updatedAt @map("updated_at")
  messages       Message[]
  documents      ConversationDocument[]
  documentChunks ConversationDocumentChunk[]
  user           User?                       @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Restrict)

  @@index([lastActiveAt(sort: Desc)])
  @@index([userId], map: "idx_conversations_user_id")
  @@map("conversations")
}

model User {
  id                                String                             @id @default(cuid())
  username                          String                             @unique
  passwordHash                      String                             @map("password_hash")
  name                              String?
  email                             String?                            @unique
  emailVerified                     DateTime?                          @map("email_verified")
  image                             String?
  sessions                          Session[]
  conversations                     Conversation[]
  jobDescriptions                   JobDescription[]
  jobDescriptionCreateRuns          JobDescriptionCreateRun[]
  jobDescriptionCreateRunEvents     JobDescriptionCreateRunEvent[]
  jobDescriptionRegenerateRuns      JobDescriptionRegenerateRun[]
  jobDescriptionRegenerateRunEvents JobDescriptionRegenerateRunEvent[]
  jobDescriptionPublishRuns         JobDescriptionPublishRun[]
  jobDescriptionPublishRunEvents    JobDescriptionPublishRunEvent[]
  jobPublishTasks                   JobPublishTask[]
  knowledgeDocuments                KnowledgeDocument[]
  knowledgeDocumentChunks           KnowledgeDocumentChunk[]
  candidates                        Candidate[]
  candidateResumes                  CandidateResume[]
  candidateResumeChunks             CandidateResumeChunk[]
  candidateScreeningRuns            CandidateScreeningRun[]
  candidateScreeningResults         CandidateScreeningResult[]
  candidateActionLogs               CandidateActionLog[]
  candidateTagStats                 CandidateTagStat[]
  candidateInterviewFeedbacks       CandidateInterviewFeedback[]
  candidateConversations            CandidateConversation[]
  candidateConversationMessages     CandidateConversationMessage[]
  candidateConversationDecisions    CandidateConversationDecision[]
  candidateConversationMemories     CandidateConversationMemory[]
  candidateCommunicationRuns        CandidateCommunicationRun[]
  companyProfile                    CompanyProfile?

  @@map("users")
}

model CompanyProfile {
  id                   String                       @id @default(uuid())
  userId               String                       @unique @map("user_id")
  name                 String
  supportedPlatforms   String[]                     @default(["boss-like"]) @map("supported_platforms")
  interviewProcesses   Json                         @default("[]") @map("interview_processes")
  createdAt            DateTime                     @default(now()) @map("created_at")
  updatedAt            DateTime                     @updatedAt @map("updated_at")
  user                 User                         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  locations            CompanyWorkLocation[]
  recruitmentPlatforms CompanyRecruitmentPlatform[]

  @@index([userId], map: "idx_company_profiles_user_id")
  @@map("company_profiles")
}

model RecruitmentPlatform {
  id               String                       @id
  label            String
  shortLabel       String                       @map("short_label")
  description      String
  kind             String
  defaultBaseUrl   String                       @map("default_base_url")
  defaultVariables Json                         @default("{}") @map("default_variables")
  isActive         Boolean                      @default(true) @map("is_active")
  createdAt        DateTime                     @default(now()) @map("created_at")
  updatedAt        DateTime                     @updatedAt @map("updated_at")
  companyConfigs   CompanyRecruitmentPlatform[]

  @@index([isActive, kind], map: "idx_recruitment_platforms_active_kind")
  @@map("recruitment_platforms")
}

model CompanyRecruitmentPlatform {
  id                String              @id @default(uuid())
  companyProfileId  String              @map("company_profile_id")
  platformId        String              @map("platform_id")
  baseUrl           String              @map("base_url")
  username          String?
  passwordEncrypted String?             @map("password_encrypted")
  variables         Json                @default("{}")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  companyProfile    CompanyProfile      @relation(fields: [companyProfileId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  platform          RecruitmentPlatform @relation(fields: [platformId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([companyProfileId, platformId], map: "company_recruitment_platforms_profile_platform_key")
  @@index([platformId], map: "idx_company_recruitment_platforms_platform")
  @@map("company_recruitment_platforms")
}

model CompanyWorkLocation {
  id               String         @id @default(uuid())
  companyProfileId String         @map("company_profile_id")
  kind             String
  label            String
  city             String?
  address          String?
  sortOrder        Int            @default(0) @map("sort_order")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([companyProfileId, sortOrder], map: "idx_company_work_locations_profile_sort")
  @@map("company_work_locations")
}

model JobDescription {
  id                             String                          @id @default(uuid())
  userId                         String                          @map("user_id")
  department                     String
  position                       String
  positionDescription            String                          @map("position_description")
  tone                           String                          @default("tech")
  status                         String                          @default("created")
  salaryRange                    String?                         @map("salary_range")
  workLocations                  Json?                           @map("work_locations")
  hiringTarget                   Int?                            @default(1) @map("hiring_target")
  activePublishBatchId           String?                         @map("active_publish_batch_id")
  publishLeaseExpiresAt          DateTime?                       @map("publish_lease_expires_at")
  content                        Json
  evaluation                     Json?
  generationMeta                 Json?                           @map("generation_meta")
  interviewProcess               Json?                           @map("interview_process")
  createdAt                      DateTime                        @default(now()) @map("created_at")
  updatedAt                      DateTime                        @updatedAt @map("updated_at")
  user                           User                            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  createRuns                     JobDescriptionCreateRun[]
  regenerateRuns                 JobDescriptionRegenerateRun[]
  publishTasks                   JobPublishTask[]
  publishRuns                    JobDescriptionPublishRun[]
  candidateScreeningRuns         CandidateScreeningRun[]
  candidateScreeningResults      CandidateScreeningResult[]
  candidateActionLogs            CandidateActionLog[]
  candidateInterviewFeedbacks    CandidateInterviewFeedback[]
  candidateConversations         CandidateConversation[]
  candidateConversationMessages  CandidateConversationMessage[]
  candidateConversationDecisions CandidateConversationDecision[]
  candidateConversationMemories  CandidateConversationMemory[]
  candidateCommunicationRuns     CandidateCommunicationRun[]

  @@unique([id, userId], map: "job_descriptions_id_user_id_key")
  @@index([userId], map: "idx_job_descriptions_user_id")
  @@index([status], map: "idx_job_descriptions_status")
  @@index([updatedAt(sort: Desc)], map: "idx_job_descriptions_updated_at")
  @@index([userId, status], map: "idx_job_descriptions_user_status")
  @@index([userId, status, publishLeaseExpiresAt], map: "idx_job_descriptions_publish_lease")
  @@map("job_descriptions")
}

model JobDescriptionCreateRun {
  id                  String                         @id @default(uuid())
  userId              String                         @map("user_id")
  jobDescriptionId    String?                        @map("job_description_id")
  department          String
  position            String
  positionDescription String                         @map("position_description")
  tone                String                         @default("tech")
  salaryRange         String                         @map("salary_range")
  workLocations       Json                           @map("work_locations")
  interviewProcess    Json?                          @map("interview_process")
  status              String                         @default("pending")
  currentStage        String?                        @map("current_stage")
  errorMessage        String?                        @map("error_message")
  startedAt           DateTime?                      @map("started_at")
  finishedAt          DateTime?                      @map("finished_at")
  createdAt           DateTime                       @default(now()) @map("created_at")
  updatedAt           DateTime                       @updatedAt @map("updated_at")
  user                User                           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  jobDescription      JobDescription?                @relation(fields: [jobDescriptionId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  events              JobDescriptionCreateRunEvent[]

  @@unique([id, userId], map: "job_description_create_runs_id_user_id_key")
  @@index([userId, createdAt(sort: Desc)], map: "idx_jd_create_runs_user_created")
  @@index([userId, jobDescriptionId, createdAt(sort: Desc)], map: "idx_jd_create_runs_user_jd_created")
  @@index([status, updatedAt(sort: Desc)], map: "idx_jd_create_runs_status_updated")
  @@map("job_description_create_runs")
}

model JobDescriptionCreateRunEvent {
  id        String                  @id @default(uuid())
  userId    String                  @map("user_id")
  runId     String                  @map("run_id")
  stage     String
  level     String                  @default("info")
  message   String
  detail    Json?
  createdAt DateTime                @default(now()) @map("created_at")
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  run       JobDescriptionCreateRun @relation(fields: [runId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)

  @@index([userId, runId, createdAt], map: "idx_jd_create_run_events_user_run_created")
  @@index([runId, createdAt], map: "idx_jd_create_run_events_run_created")
  @@map("job_description_create_run_events")
}

model JobDescriptionRegenerateRun {
  id               String                             @id @default(uuid())
  userId           String                             @map("user_id")
  jobDescriptionId String                             @map("job_description_id")
  tone             String                             @default("tech")
  extraInstruction String                             @default("") @map("extra_instruction")
  currentJd        Json                               @map("current_jd")
  status           String                             @default("pending")
  currentStage     String?                            @map("current_stage")
  errorMessage     String?                            @map("error_message")
  startedAt        DateTime?                          @map("started_at")
  finishedAt       DateTime?                          @map("finished_at")
  createdAt        DateTime                           @default(now()) @map("created_at")
  updatedAt        DateTime                           @updatedAt @map("updated_at")
  user             User                               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  jobDescription   JobDescription                     @relation(fields: [jobDescriptionId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  events           JobDescriptionRegenerateRunEvent[]

  @@unique([id, userId], map: "job_description_regenerate_runs_id_user_id_key")
  @@unique([id, userId, jobDescriptionId], map: "job_description_regenerate_runs_id_user_jd_key")
  @@index([userId, jobDescriptionId, createdAt(sort: Desc)], map: "idx_jd_regenerate_runs_user_jd_created")
  @@index([status, updatedAt(sort: Desc)], map: "idx_jd_regenerate_runs_status_updated")
  @@map("job_description_regenerate_runs")
}

model JobDescriptionRegenerateRunEvent {
  id               String                      @id @default(uuid())
  userId           String                      @map("user_id")
  runId            String                      @map("run_id")
  jobDescriptionId String                      @map("job_description_id")
  stage            String
  level            String                      @default("info")
  message          String
  detail           Json?
  createdAt        DateTime                    @default(now()) @map("created_at")
  user             User                        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  run              JobDescriptionRegenerateRun @relation(fields: [runId, userId, jobDescriptionId], references: [id, userId, jobDescriptionId], onDelete: Cascade, onUpdate: Restrict)

  @@index([userId, runId, createdAt], map: "idx_jd_regenerate_run_events_user_run_created")
  @@index([runId, createdAt], map: "idx_jd_regenerate_run_events_run_created")
  @@map("job_description_regenerate_run_events")
}

model JobDescriptionPublishRun {
  id               String                          @id @default(uuid())
  userId           String                          @map("user_id")
  jobDescriptionId String                          @map("job_description_id")
  batchId          String                          @default(dbgenerated("gen_random_uuid()::text")) @map("batch_id")
  platform         String
  status           String                          @default("pending")
  currentStage     String?                         @map("current_stage")
  errorMessage     String?                         @map("error_message")
  publishTaskId    String?                         @map("publish_task_id")
  skillId          String?                         @map("skill_id")
  startedAt        DateTime?                       @map("started_at")
  finishedAt       DateTime?                       @map("finished_at")
  createdAt        DateTime                        @default(now()) @map("created_at")
  updatedAt        DateTime                        @updatedAt @map("updated_at")
  user             User                            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  jobDescription   JobDescription                  @relation(fields: [jobDescriptionId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  events           JobDescriptionPublishRunEvent[]

  @@unique([id, userId], map: "job_description_publish_runs_id_user_id_key")
  @@index([userId, createdAt(sort: Desc)], map: "idx_jd_publish_runs_user_created")
  @@index([userId, jobDescriptionId, createdAt(sort: Desc)], map: "idx_jd_publish_runs_user_jd_created")
  @@index([userId, jobDescriptionId, batchId], map: "idx_jd_publish_runs_user_jd_batch")
  @@index([status, updatedAt(sort: Desc)], map: "idx_jd_publish_runs_status_updated")
  @@map("job_description_publish_runs")
}

model JobDescriptionPublishRunEvent {
  id        String                   @id @default(uuid())
  userId    String                   @map("user_id")
  runId     String                   @map("run_id")
  stage     String
  level     String                   @default("info")
  message   String
  detail    Json?
  createdAt DateTime                 @default(now()) @map("created_at")
  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  run       JobDescriptionPublishRun @relation(fields: [runId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)

  @@index([userId, runId, createdAt], map: "idx_jd_publish_run_events_user_run_created")
  @@index([runId, createdAt], map: "idx_jd_publish_run_events_run_created")
  @@map("job_description_publish_run_events")
}

model PublishSkill {
  id              String            @id @default(uuid())
  name            String
  platform        String
  siteFingerprint String            @default("default") @map("site_fingerprint")
  description     String
  version         Int
  isActive        Boolean           @default(true) @map("is_active")
  inputSchema     Json              @map("input_schema")
  variables       Json
  steps           Json
  meta            Json?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  tasks           JobPublishTask[]
  traces          JobPublishTrace[]

  @@unique([name, platform, siteFingerprint, version], map: "publish_skills_name_platform_site_version_key")
  @@index([name, platform, siteFingerprint, isActive, version], map: "idx_publish_skills_lookup")
  @@index([platform, isActive], map: "idx_publish_skills_platform_active")
  @@map("publish_skills")
}

model JobPublishTask {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  jobDescriptionId String           @map("job_description_id")
  batchId          String?          @map("batch_id")
  skillId          String           @map("skill_id")
  platform         String
  input            Json
  currentStep      String?          @map("current_step")
  status           String           @default("running")
  errorMessage     String?          @map("error_message")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  jobDescription   JobDescription   @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  skill            PublishSkill     @relation(fields: [skillId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  trace            JobPublishTrace?

  @@index([userId, jobDescriptionId, createdAt(sort: Desc)], map: "idx_job_publish_tasks_user_jd_created")
  @@index([userId, jobDescriptionId, batchId], map: "idx_job_publish_tasks_user_jd_batch")
  @@index([status], map: "idx_job_publish_tasks_status")
  @@index([skillId], map: "idx_job_publish_tasks_skill_id")
  @@map("job_publish_tasks")
}

model JobPublishTrace {
  id        String         @id @default(uuid())
  taskId    String         @unique @map("task_id")
  skillId   String         @map("skill_id")
  status    String
  steps     Json
  createdAt DateTime       @default(now()) @map("created_at")
  task      JobPublishTask @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  skill     PublishSkill   @relation(fields: [skillId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([skillId], map: "idx_job_publish_traces_skill_id")
  @@index([status], map: "idx_job_publish_traces_status")
  @@map("job_publish_traces")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([userId], map: "idx_sessions_user_id")
  @@map("sessions")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  role           String
  content        String
  documentId     String?      @map("document_id")
  seq            Int
  tokenCount     Int?         @map("token_count")
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([conversationId, seq])
  @@index([conversationId, seq], map: "idx_messages_conversation_seq")
  @@map("messages")
}

model ConversationDocument {
  id              String                         @id @default(uuid())
  conversationId  String                         @map("conversation_id")
  filename        String
  contentMarkdown String                         @map("content_markdown")
  status          String                         @default("processing")
  errorMessage    String?                        @map("error_message")
  version         Int                            @default(1)
  createdAt       DateTime                       @default(now()) @map("created_at")
  updatedAt       DateTime                       @updatedAt @map("updated_at")
  chunks          ConversationDocumentChunk[]
  jobs            ConversationDocumentIndexJob[]
  conversation    Conversation                   @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([id, conversationId], map: "conversation_documents_id_conversation_id_key")
  @@index([conversationId], map: "idx_conversation_documents_conversation_id")
  @@index([status], map: "idx_conversation_documents_status")
  @@map("conversation_documents")
}

model ConversationDocumentChunk {
  id                 String                 @id @default(uuid())
  documentId         String                 @map("document_id")
  conversationId     String                 @map("conversation_id")
  chunkIndex         Int                    @map("chunk_index")
  content            String
  tokenEstimate      Int?                   @map("token_estimate")
  embeddingModel     String                 @map("embedding_model")
  embeddingDimension Int                    @map("embedding_dimension")
  embedding          Unsupported("vector")?
  createdAt          DateTime               @default(now()) @map("created_at")
  document           ConversationDocument   @relation(fields: [documentId, conversationId], references: [id, conversationId], onDelete: Cascade, onUpdate: Restrict)
  conversation       Conversation           @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([documentId, chunkIndex], map: "conversation_document_chunks_document_id_chunk_index_key")
  @@index([documentId], map: "idx_conversation_document_chunks_document_id")
  @@index([conversationId], map: "idx_conversation_document_chunks_conversation_id")
  @@index([conversationId, chunkIndex], map: "idx_conversation_document_chunks_conversation_chunk_index")
  @@index([conversationId, embeddingModel, embeddingDimension], map: "idx_conversation_document_chunks_conversation_embedding")
  @@map("conversation_document_chunks")
}

model ConversationDocumentIndexJob {
  id         String               @id @default(uuid())
  documentId String               @map("document_id")
  status     String               @default("pending")
  attempts   Int                  @default(0)
  lastError  String?              @map("last_error")
  startedAt  DateTime?            @map("started_at")
  finishedAt DateTime?            @map("finished_at")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")
  document   ConversationDocument @relation(fields: [documentId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([documentId], map: "idx_conversation_document_index_jobs_document_id")
  @@index([status], map: "idx_conversation_document_index_jobs_status")
  @@map("conversation_document_index_jobs")
}

model KnowledgeDocument {
  id              String                      @id @default(uuid())
  userId          String                      @map("user_id")
  filename        String
  title           String?
  sourceLabel     String?                     @map("source_label")
  contentMarkdown String                      @map("content_markdown")
  status          String                      @default("processing")
  errorMessage    String?                     @map("error_message")
  version         Int                         @default(1)
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")
  user            User                        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  chunks          KnowledgeDocumentChunk[]
  jobs            KnowledgeDocumentIndexJob[]

  @@unique([id, userId], map: "knowledge_documents_id_user_id_key")
  @@index([userId], map: "idx_knowledge_documents_user_id")
  @@index([status], map: "idx_knowledge_documents_status")
  @@index([userId, sourceLabel], map: "idx_knowledge_documents_user_source_label")
  @@map("knowledge_documents")
}

model KnowledgeDocumentChunk {
  id                 String                 @id @default(uuid())
  documentId         String                 @map("document_id")
  userId             String                 @map("user_id")
  chunkIndex         Int                    @map("chunk_index")
  content            String
  tokenEstimate      Int?                   @map("token_estimate")
  embeddingModel     String                 @map("embedding_model")
  embeddingDimension Int                    @map("embedding_dimension")
  embedding          Unsupported("vector")?
  createdAt          DateTime               @default(now()) @map("created_at")
  document           KnowledgeDocument      @relation(fields: [documentId, userId], references: [id, userId], onDelete: Cascade, onUpdate: Restrict)
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@unique([documentId, chunkIndex], map: "knowledge_document_chunks_document_id_chunk_index_key")
  @@index([documentId], map: "idx_knowledge_document_chunks_document_id")
  @@index([userId], map: "idx_knowledge_document_chunks_user_id")
  @@index([userId, embeddingModel, embeddingDimension], map: "idx_knowledge_document_chunks_user_embedding")
  @@map("knowledge_document_chunks")
}

model KnowledgeDocumentIndexJob {
  id         String            @id @default(uuid())
  documentId String            @map("document_id")
  status     String            @default("pending")
  attempts   Int               @default(0)
  lastError  String?           @map("last_error")
  startedAt  DateTime?         @map("started_at")
  finishedAt DateTime?         @map("finished_at")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([documentId], map: "idx_knowledge_document_index_jobs_document_id")
  @@index([status], map: "idx_knowledge_document_index_jobs_status")
  @@map("knowledge_document_index_jobs")
}

model Candidate {
  id                    String                          @id @default(uuid())
  userId                String                          @map("user_id")
  displayName           String                          @map("display_name")
  currentTitle          String?                         @map("current_title")
  currentCompany        String?                         @map("current_company")
  location              String?
  experienceYears       Float?                          @map("experience_years")
  sourcePlatform        String                          @map("source_platform")
  platformCandidateId   String?                         @map("platform_candidate_id")
  profileUrl            String?                         @map("profile_url")
  identityKey           String                          @map("identity_key")
  identityHash          String                          @map("identity_hash")
  lastActiveAt          DateTime?                       @map("last_active_at")
  contacted             Boolean                         @default(false)
  replied               Boolean                         @default(false)
  lastContactAt         DateTime?                       @map("last_contact_at")
  createdAt             DateTime                        @default(now()) @map("created_at")
  updatedAt             DateTime                        @updatedAt @map("updated_at")
  user                  User                            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  resumes               CandidateResume[]
  chunks                CandidateResumeChunk[]
  screeningResults      CandidateScreeningResult[]
  actionLogs            CandidateActionLog[]
  interviewFeedbacks    CandidateInterviewFeedback[]
  conversations         CandidateConversation[]
