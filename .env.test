# Test Environment Variables

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Hiring Agent (Test)"
NEXT_PUBLIC_APP_DESCRIPTION="AI-powered hiring assistant (test)"

NEXT_PUBLIC_ENABLE_MSW=true

# Chat persistence (PostgreSQL + Redis)
DATABASE_URL=postgresql://apple@127.0.0.1:5432/bia
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=apple
POSTGRES_PASSWORD=
POSTGRES_DATABASE=bia
POSTGRES_CI_SUFFIX=_ci
REDIS_URL=redis://127.0.0.1:6379
CHAT_REDIS_TTL_SECONDS=86400
CHAT_HISTORY_REHYDRATE_LIMIT=50
CHAT_TEST_REDIS_PREFIX=chat:test
